# ─── DATABASE ────────────────────────────────────────────────────────────────
# PostgreSQL connection string — update user, password, host, and database name
DATABASE_URL=postgresql://dev:devpassword@localhost:5432/shipping_portal

# ─── JWT AUTH ─────────────────────────────────────────────────────────────────
# Secret keys for signing JWT tokens — use strong random strings (min 32 chars)
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
# Token expiration times
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── XPO LOGISTICS ────────────────────────────────────────────────────────────
# OAuth 2.0 credentials — get from XPO Developer Portal
XPO_CLIENT_ID=your_xpo_client_id
XPO_CLIENT_SECRET=your_xpo_client_secret
XPO_ACCOUNT_NUMBER=your_xpo_account_number

# ─── R+L CARRIERS ─────────────────────────────────────────────────────────────
# API Key — get from R+L Carriers account manager
RL_API_KEY=your_rl_carriers_api_key
RL_ACCOUNT_NUMBER=your_rl_account_number

# ─── SEFL ─────────────────────────────────────────────────────────────────────
# SOAP credentials — get from SEFL account representative
SEFL_USERNAME=your_sefl_username
SEFL_PASSWORD=your_sefl_password
SEFL_ACCOUNT_NUMBER=your_sefl_account_number
# SEFL SOAP WSDL endpoint URL
SEFL_WSDL_URL=https://www.sefl.com/WebServices/RateQuote.asmx?WSDL

# ─── FEDEX FREIGHT ────────────────────────────────────────────────────────────
# OAuth 2.0 credentials — get from FedEx Developer Portal
FEDEX_CLIENT_ID=your_fedex_client_id
FEDEX_CLIENT_SECRET=your_fedex_client_secret
FEDEX_ACCOUNT_NUMBER=your_fedex_account_number

# ─── SHIPPING CONFIG ──────────────────────────────────────────────────────────
# Default warehouse origin ZIP code
ORIGIN_ZIP=30301
# Public URL of the shipping portal API
PORTAL_API_URL=https://api.yourdomain.com

# ─── MAGENTO WEBHOOK ──────────────────────────────────────────────────────────
# HMAC secret for verifying Magento webhook payloads — must match Magento config
MAGENTO_WEBHOOK_SECRET=your_webhook_hmac_secret

# ─── APP ──────────────────────────────────────────────────────────────────────
# Environment: development, staging, production
NODE_ENV=development
# API server port
PORT=3001
# Admin dashboard URL (for CORS)
ADMIN_DASHBOARD_URL=https://portal.yourdomain.com
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://cabinets.deals,https://www.northvillecabinetry.com
