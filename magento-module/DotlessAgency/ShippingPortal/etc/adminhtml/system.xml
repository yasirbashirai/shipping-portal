<?xml version="1.0"?>
<!--
  Admin configuration UI for ShippingPortal
  Stores > Configuration > Shipping > Shipping Portal
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="carriers">
            <group id="shippingportal" translate="label" type="text" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Shipping Portal (LTL Freight)</label>
                <field id="active" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="title" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1">
                    <label>Title</label>
                </field>
                <field id="portal_api_url" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1">
                    <label>Portal API URL</label>
                    <comment>Full URL to the shipping portal API (e.g., https://api.yourdomain.com)</comment>
                </field>
                <field id="api_secret_key" translate="label comment" type="obscure" sortOrder="40" showInDefault="1" showInWebsite="1">
                    <label>API Secret Key</label>
                    <comment>Used for HMAC verification of webhook payloads</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
                <field id="origin_zip" translate="label" type="text" sortOrder="50" showInDefault="1" showInWebsite="1">
                    <label>Origin ZIP Code</label>
                </field>
                <field id="source_website" translate="label comment" type="select" sortOrder="60" showInDefault="1" showInWebsite="1">
                    <label>Source Website Identifier</label>
                    <comment>Which website is this Magento store associated with</comment>
                    <option>
                        <value id="cabinets_deals">cabinets.deals</value>
                        <value id="northville_cabinetry">northvillecabinetry.com</value>
                    </option>
                </field>
            </group>
        </section>
    </system>
</config>
