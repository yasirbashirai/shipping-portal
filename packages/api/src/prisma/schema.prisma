generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── MODELS ───────────────────────────────────────────────────────────────────
// Note: SQLite does not support enums, so enum fields use String type.
// Valid values are enforced at the application layer via Zod validation.
//
// OrderStatus: PENDING | PROCESSING | BOOKED | IN_TRANSIT | DELIVERED | CANCELLED | ON_HOLD
// DeliveryLocationType: RESIDENTIAL | COMMERCIAL
// DeliveryMethod: CURBSIDE | INSIDE_DELIVERY
// CabinetType: RTA | ASSEMBLED
// CarrierName: XPO | RL_CARRIERS | SEFL | FEDEX_FREIGHT
// SourceWebsite: CABINETS_DEALS | NORTHVILLE_CABINETRY
// UserRole: OWNER | STAFF

model Customer {
  id            String   @id @default(cuid())
  email         String   @unique
  firstName     String
  lastName      String
  phone         String?
  magentoId     String?
  sourceWebsite String   // SourceWebsite enum
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]

  @@index([email])
  @@index([sourceWebsite])
}

model Order {
  id                String           @id @default(cuid())
  orderNumber       String           @unique
  magentoOrderId    String?          @unique
  sourceWebsite     String           // SourceWebsite enum
  status            String           @default("PENDING") // OrderStatus enum
  customer          Customer         @relation(fields: [customerId], references: [id])
  customerId        String
  shipmentDetails   ShipmentDetails?
  rateQuotes        RateQuote[]
  selectedRateId    String?
  selectedRate      RateQuote?       @relation("SelectedRate", fields: [selectedRateId], references: [id])
  trackingNumber    String?
  carrierBooked     String?          // CarrierName enum
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  totalAmount       Float?
  shippingCost      Float?
  notes             String?
  adminNotes        String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  auditLogs         AuditLog[]

  @@index([status])
  @@index([sourceWebsite])
  @@index([createdAt])
  @@index([customerId])
}

model ShipmentDetails {
  id                   String   @id @default(cuid())
  order                Order    @relation(fields: [orderId], references: [id])
  orderId              String   @unique
  originZip            String
  destinationZip       String
  destinationCity      String?
  destinationState     String?
  cabinetCount         Int
  cabinetType          String   // CabinetType enum
  hasLazySusan         Boolean  @default(false)
  lazySusanQty         Int?
  hasVentHood          Boolean  @default(false)
  ventHoodQty          Int?
  hasDrawers           Boolean  @default(false)
  drawerQty            Int?
  deliveryLocationType String   // DeliveryLocationType enum
  deliveryMethod       String   // DeliveryMethod enum
  appointmentRequired  Boolean  @default(false)
  estimatedWeight      Float
  freightClass         String?
  estimatedPallets     Int?
  createdAt            DateTime @default(now())
}

model RateQuote {
  id                String   @id @default(cuid())
  order             Order    @relation(fields: [orderId], references: [id])
  orderId           String
  carrier           String   // CarrierName enum
  serviceLevel      String
  totalCost         Float
  transitDays       Int
  estimatedDelivery DateTime
  rawResponse       String   // JSON stored as string for SQLite
  quotedAt          DateTime @default(now())
  isSelected        Boolean  @default(false)
  selectedOrders    Order[]  @relation("SelectedRate")
}

model AdminUser {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  password      String
  role          String         @default("STAFF") // UserRole enum
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id          String    @id @default(cuid())
  token       String    @unique
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])
  adminUserId String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String
  action      String
  oldValue    String?
  newValue    String?
  performedBy String?
  createdAt   DateTime @default(now())

  @@index([orderId])
}
