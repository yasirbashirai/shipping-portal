generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PROCESSING
  BOOKED
  IN_TRANSIT
  DELIVERED
  CANCELLED
  ON_HOLD
}

enum DeliveryLocationType {
  RESIDENTIAL
  COMMERCIAL
}

enum DeliveryMethod {
  CURBSIDE
  INSIDE_DELIVERY
}

enum CabinetType {
  RTA
  ASSEMBLED
}

enum CarrierName {
  XPO
  RL_CARRIERS
  SEFL
  FEDEX_FREIGHT
}

enum SourceWebsite {
  CABINETS_DEALS
  NORTHVILLE_CABINETRY
}

enum UserRole {
  OWNER
  STAFF
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

model Customer {
  id            String        @id @default(cuid())
  email         String        @unique
  firstName     String
  lastName      String
  phone         String?
  magentoId     String?
  sourceWebsite SourceWebsite
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  orders        Order[]

  @@index([email])
  @@index([sourceWebsite])
}

model Order {
  id               String        @id @default(cuid())
  orderNumber      String        @unique
  magentoOrderId   String?       @unique
  sourceWebsite    SourceWebsite
  status           OrderStatus   @default(PENDING)
  customer         Customer      @relation(fields: [customerId], references: [id])
  customerId       String
  shipmentDetails  ShipmentDetails?
  rateQuotes       RateQuote[]
  selectedRateId   String?
  selectedRate     RateQuote?    @relation("SelectedRate", fields: [selectedRateId], references: [id])
  trackingNumber   String?
  carrierBooked    CarrierName?
  estimatedDelivery DateTime?
  actualDelivery   DateTime?
  totalAmount      Decimal?      @db.Decimal(10, 2)
  shippingCost     Decimal?      @db.Decimal(10, 2)
  notes            String?       @db.Text
  adminNotes       String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  auditLogs        AuditLog[]

  @@index([status])
  @@index([sourceWebsite])
  @@index([createdAt])
  @@index([customerId])
}

model ShipmentDetails {
  id                   String               @id @default(cuid())
  order                Order                @relation(fields: [orderId], references: [id])
  orderId              String               @unique
  originZip            String
  destinationZip       String
  destinationCity      String?
  destinationState     String?
  cabinetCount         Int
  cabinetType          CabinetType
  hasLazySusan         Boolean              @default(false)
  lazySusanQty         Int?
  hasVentHood          Boolean              @default(false)
  ventHoodQty          Int?
  hasDrawers           Boolean              @default(false)
  drawerQty            Int?
  deliveryLocationType DeliveryLocationType
  deliveryMethod       DeliveryMethod
  appointmentRequired  Boolean              @default(false)
  estimatedWeight      Decimal              @db.Decimal(10, 2)
  freightClass         String?
  estimatedPallets     Int?
  createdAt            DateTime             @default(now())
}

model RateQuote {
  id                String      @id @default(cuid())
  order             Order       @relation(fields: [orderId], references: [id])
  orderId           String
  carrier           CarrierName
  serviceLevel      String
  totalCost         Decimal     @db.Decimal(10, 2)
  transitDays       Int
  estimatedDelivery DateTime
  rawResponse       Json
  quotedAt          DateTime    @default(now())
  isSelected        Boolean     @default(false)
  selectedOrders    Order[]     @relation("SelectedRate")
}

model AdminUser {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  password      String
  role          UserRole       @default(STAFF)
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id          String    @id @default(cuid())
  token       String    @unique
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])
  adminUserId String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String
  action      String
  oldValue    String?
  newValue    String?
  performedBy String?
  createdAt   DateTime @default(now())

  @@index([orderId])
}
